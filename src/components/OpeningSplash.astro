	@media (prefers-reduced-motion: reduce) {
		.opening-splash,
		.opening-splash *,
		.opening-splash *::before,
		.opening-splash *::after {
			animation: none !important;
			transition: none !important;
		}
	}
</style>

<script>
	class OpeningSplash extends HTMLElement {
		private percent = 0;
		private timer?: number;

		connectedCallback() {
			const seen = this.hasSeenSplash();
			if (seen) {
				this.remove();
				return;
			}

			document.body.classList.add("opening-splash-lock");

			if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
				this.finishReducedMotion();
				return;
			}

			this.tick();
		}

		disconnectedCallback() {
			document.body.classList.remove("opening-splash-lock");
			if (this.timer) window.clearTimeout(this.timer);
		}

		private hasSeenSplash() {
			try {
				return sessionStorage.getItem("drawrain-opening-splash") === "done";
			} catch {
				return false;
			}
		}

		private markSeen() {
			try {
				sessionStorage.setItem("drawrain-opening-splash", "done");
			} catch {
				// Session storage may be blocked. The animation still works for this page view.
			}
		}

		private finishReducedMotion() {
			this.markSeen();
			document.documentElement.classList.add("opening-splash-seen");
			document.body.classList.remove("opening-splash-lock");
			this.remove();
		}

		private tick() {
			const jump = Math.ceil(14 + Math.random() * 20);
			this.percent = Math.min(100, this.percent + jump);
			this.style.setProperty("--splash-progress", `${this.percent}%`);

			const percentEl = this.querySelector<HTMLElement>(".progress-percent");
			if (percentEl) percentEl.textContent = `${this.percent}%`;

			if (this.percent >= 100) {
				this.completeSoon(120);
				return;
			}

			this.timer = window.setTimeout(() => this.tick(), 42 + Math.random() * 48);
		}

		private completeSoon(delay: number) {
			this.style.setProperty("--splash-progress", "100%");
			const percentEl = this.querySelector<HTMLElement>(".progress-percent");
			if (percentEl) percentEl.textContent = "100%";
			this.timer = window.setTimeout(() => {
				this.classList.add("is-complete");
				this.markSeen();
				this.timer = window.setTimeout(() => {
					this.classList.add("is-revealing");
					document.body.classList.remove("opening-splash-lock");
					this.timer = window.setTimeout(() => {
						this.classList.add("is-leaving");
						this.timer = window.setTimeout(() => {
							document.documentElement.classList.add("opening-splash-seen");
							this.remove();
						}, 320);
					}, 460);
				}, 320);
			}, delay);
		}
	}

	if (!customElements.get("opening-splash")) {
		customElements.define("opening-splash", OpeningSplash);
	}
</script>
