---
import EnglishB2QuizApp from "@components/EnglishB2Quiz.svelte";
import Layout from "@layouts/Layout.astro";
import { parseEnglishB2Quiz } from "@utils/english-b2-quiz";
import { url } from "@utils/url-utils";
import englishB2Markdown from "../content/posts/EnglishB2.md?raw";

const questions = parseEnglishB2Quiz(englishB2Markdown);
---

<Layout
	title="大学英语 B2 刷题模式"
	description="大学英语 B2 期末复习刷题页面，支持按单元练习、错题复习、收藏和解析。"
	bodyClass="quiz-immersive-page"
	disableOpeningSplash={true}
>
	<main class="quiz-stage">
		<nav class="quiz-topbar" aria-label="刷题页面导航">
			<a href={url("/")} class="brand-link" data-no-swup>Drawrain's Blog</a>
			<div class="topbar-links">
				<a href={url("/posts/englishb2/")} data-no-swup>复习原文</a>
				<a href={url("/archive/")} data-no-swup>归档</a>
			</div>
		</nav>

		<EnglishB2QuizApp questions={questions} client:load />
	</main>
	<div id="toc" hidden></div>
</Layout>

<style is:global>
	body.quiz-immersive-page {
		min-height: 100vh;
		overflow-x: hidden;
		background:
			radial-gradient(circle at 18% 14%, rgba(45, 212, 191, 0.16), transparent 22rem),
			radial-gradient(circle at 82% 18%, rgba(251, 146, 60, 0.12), transparent 24rem),
			linear-gradient(135deg, #020617, #0b1120 48%, #101827);
	}

	body.quiz-immersive-page::before {
		content: "";
		position: fixed;
		inset: 0;
		z-index: -2;
		background-image:
			linear-gradient(rgba(148, 163, 184, 0.07) 1px, transparent 1px),
			linear-gradient(90deg, rgba(148, 163, 184, 0.06) 1px, transparent 1px);
		background-size: 3rem 3rem;
		mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.82), transparent 92%);
	}

	body.quiz-immersive-page::after {
		content: "";
		position: fixed;
		inset: 0;
		z-index: -1;
		background: linear-gradient(180deg, rgba(2, 6, 23, 0.05), rgba(2, 6, 23, 0.68));
		pointer-events: none;
	}

	body.quiz-immersive-page #page-height-extend,
	body.quiz-immersive-page #opening-splash,
	body.quiz-immersive-page #top-row,
	body.quiz-immersive-page #banner-wrapper,
	body.quiz-immersive-page #toc-wrapper {
		display: none !important;
	}

	.quiz-stage {
		position: relative;
		width: min(100% - 1rem, 82rem);
		margin: 0 auto;
		padding: 1rem 0.5rem 2rem;
	}

	.quiz-topbar {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 0.9rem;
		border: 1px solid rgba(226, 232, 240, 0.11);
		border-radius: 1rem;
		background: rgba(15, 23, 42, 0.58);
		padding: 0.65rem 0.75rem;
		box-shadow: 0 18px 48px rgba(0, 0, 0, 0.18);
		backdrop-filter: blur(18px);
		-webkit-backdrop-filter: blur(18px);
	}

	.quiz-topbar a {
		border-radius: 0.7rem;
		color: rgba(226, 232, 240, 0.82);
		font-weight: 850;
		letter-spacing: 0;
		text-decoration: none;
		transition:
			background-color 160ms ease,
			color 160ms ease;
	}

	.quiz-topbar a:hover {
		color: var(--primary);
	}

	.brand-link {
		padding: 0.55rem 0.7rem;
		color: var(--primary) !important;
	}

	.topbar-links {
		display: flex;
		flex-wrap: wrap;
		justify-content: flex-end;
		gap: 0.35rem;
	}

	.topbar-links a {
		padding: 0.55rem 0.7rem;
	}

	.topbar-links a:hover,
	.brand-link:hover {
		background: rgba(148, 163, 184, 0.12);
	}

	@media (min-width: 768px) {
		.quiz-stage {
			width: min(100% - 2rem, 82rem);
			padding: 1.25rem 1rem 3rem;
		}
	}
</style>
