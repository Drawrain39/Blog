---
import MilitaryTheoryQuizApp from "@components/MilitaryTheoryQuiz.svelte";
import Layout from "@layouts/Layout.astro";
import type { MilitaryTheoryData } from "@utils/military-theory-quiz";
import { url } from "@utils/url-utils";
import militaryTheoryQuizData from "../data/military-theory-quiz.json";

const quizData = militaryTheoryQuizData as MilitaryTheoryData;
---

<Layout
	title="军事理论刷题模式"
	description="军事理论期末复习刷题页面，覆盖选择、填空、判断、简答、论述和知识点复习。"
	bodyClass="military-quiz-page"
	disableOpeningSplash={true}
>
	<main class="military-stage">
		<nav class="military-topbar" aria-label="刷题页面导航">
			<a href={url("/")} class="brand-link" data-no-swup>Drawrain's Blog</a>
			<div class="topbar-links">
				<a href={url("/posts/military-theory/")} data-no-swup>复习原文</a>
				<a href={url("/archive/")} data-no-swup>归档</a>
			</div>
		</nav>

		<MilitaryTheoryQuizApp data={quizData} client:load />
	</main>
	<div id="toc" hidden></div>
</Layout>

<style is:global>
	body.military-quiz-page {
		min-height: 100vh;
		overflow-x: hidden;
		background:
			linear-gradient(rgba(232, 224, 202, 0.045) 1px, transparent 1px),
			linear-gradient(90deg, rgba(232, 224, 202, 0.04) 1px, transparent 1px),
			linear-gradient(135deg, #11130f, #1b2118 48%, #10110f);
		background-size:
			3rem 3rem,
			3rem 3rem,
			auto;
	}

	body.military-quiz-page::after {
		content: "";
		position: fixed;
		inset: 0;
		z-index: -1;
		background: linear-gradient(180deg, rgba(14, 16, 14, 0), rgba(14, 16, 14, 0.72));
		pointer-events: none;
	}

	body.military-quiz-page #page-height-extend,
	body.military-quiz-page #opening-splash,
	body.military-quiz-page #top-row,
	body.military-quiz-page #banner-wrapper,
	body.military-quiz-page #toc-wrapper {
		display: none !important;
	}

	.military-stage {
		position: relative;
		width: min(100% - 1rem, 86rem);
		margin: 0 auto;
		padding: 1rem 0.5rem 2rem;
	}

	.military-topbar {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 0.85rem;
		border: 1px solid rgba(232, 224, 202, 0.14);
		border-radius: 0.5rem;
		background: rgba(17, 20, 18, 0.68);
		padding: 0.62rem 0.7rem;
		box-shadow: 0 18px 48px rgba(0, 0, 0, 0.2);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
	}

	.military-topbar a {
		border-radius: 0.45rem;
		color: rgba(245, 239, 225, 0.84);
		font-weight: 850;
		letter-spacing: 0;
		text-decoration: none;
		transition:
			background-color 160ms ease,
			color 160ms ease;
	}

	.military-topbar a:hover {
		color: #d8a838;
	}

	.brand-link {
		padding: 0.52rem 0.65rem;
		color: #d8a838 !important;
	}

	.topbar-links {
		display: flex;
		flex-wrap: wrap;
		justify-content: flex-end;
		gap: 0.35rem;
	}

	.topbar-links a {
		padding: 0.52rem 0.65rem;
	}

	.topbar-links a:hover,
	.brand-link:hover {
		background: rgba(232, 224, 202, 0.1);
	}

	@media (min-width: 768px) {
		.military-stage {
			width: min(100% - 2rem, 86rem);
			padding: 1.25rem 1rem 3rem;
		}
	}
</style>
