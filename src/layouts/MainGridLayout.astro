---
import BackToTop from "@components/control/BackToTop.astro";
import Footer from "@components/Footer.astro";
import Navbar from "@components/Navbar.astro";
import SideBar from "@components/widget/SideBar.astro";
import type { MarkdownHeading } from "astro";
import { Icon } from "astro-icon/components";
import ImageWrapper from "../components/misc/ImageWrapper.astro";
import TOC from "../components/widget/TOC.astro";
import { siteConfig } from "../config";
import {
	BANNER_HEIGHT,
	BANNER_HEIGHT_EXTEND,
	MAIN_PANEL_OVERLAPS_BANNER_HEIGHT,
} from "../constants/constants";
import Layout from "./Layout.astro";

interface Props {
	title?: string;
	banner?: string;
	description?: string;
	lang?: string;
	setOGTypeArticle?: boolean;
	headings?: MarkdownHeading[];
	articleLayout?: boolean;
}

const {
	title,
	banner,
	description,
	lang,
	setOGTypeArticle,
	headings = [],
	articleLayout = false,
} = Astro.props;
const hasBannerCredit =
	siteConfig.banner.enable && siteConfig.banner.credit.enable;
const hasBannerLink = !!siteConfig.banner.credit.url;

const mainPanelTop = siteConfig.banner.enable
	? `calc(${BANNER_HEIGHT}vh - ${MAIN_PANEL_OVERLAPS_BANNER_HEIGHT}rem)`
	: "5.5rem";
---

<Layout title={title} banner={banner} description={description} lang={lang} setOGTypeArticle={setOGTypeArticle}>

<!-- Navbar -->
<slot slot="head" name="head"></slot>
<div id="top-row" class="z-50 pointer-events-none relative transition-all duration-700 max-w-[var(--page-width)] px-0 md:px-4 mx-auto" class:list={[""]}>
    <div id="navbar-wrapper" class="pointer-events-auto sticky top-0 transition-all">
        <Navbar></Navbar>
    </div>
</div>

<!-- Banner -->
{siteConfig.banner.enable && <div id="banner-wrapper" class={`absolute z-10 w-full transition duration-700 overflow-hidden`} style={`top: -${BANNER_HEIGHT_EXTEND}vh`}>
    <ImageWrapper id="banner" alt="Banner image of the blog" class:list={["object-cover h-full transition duration-700 opacity-0 scale-105"]}
                  src={siteConfig.banner.src} position={siteConfig.banner.position}
    >
    </ImageWrapper>
</div>}

<!-- Main content -->
<div class="absolute w-full z-30 pointer-events-none" style={`top: ${mainPanelTop}`}>
    <!-- The pointer-events-none here prevent blocking the click event of the TOC -->
    <div class="relative max-w-[var(--page-width)] mx-auto pointer-events-auto">
        <div id="main-grid" class:list={[
            "transition duration-700 w-full left-0 right-0 grid grid-cols-[17.5rem_auto] grid-rows-[auto_1fr_auto] lg:grid-rows-[auto] mx-auto gap-4 px-0 md:px-4",
            {"article-grid": articleLayout},
        ]}
        >
            <!-- Banner image credit -->
            {hasBannerCredit && <a href={siteConfig.banner.credit.url} id="banner-credit" target="_blank" rel="noopener" aria-label="Visit image source"
                                   class:list={["group onload-animation transition-all absolute flex justify-center items-center rounded-full " +
                                   "px-3 right-4 -top-[3.25rem] bg-black/60 hover:bg-black/70 h-9", {"hover:pr-9 active:bg-black/80": hasBannerLink}]}
            >
                <Icon class="text-white/75 text-[1.25rem] mr-1" name="material-symbols:copyright-outline-rounded" ></Icon>
                <div class="text-white/75 text-xs">{siteConfig.banner.credit.text}</div>
                <Icon class:list={["transition absolute text-[oklch(0.75_0.14_var(--hue))] right-4 text-[0.75rem] opacity-0",
                    {"group-hover:opacity-100": hasBannerLink}]}
                      name="fa6-solid:arrow-up-right-from-square">
                </Icon>
            </a>}


            {!articleLayout && <SideBar class="mb-4 row-start-2 row-end-3 col-span-2 lg:row-start-1 lg:row-end-2 lg:col-span-1 lg:max-w-[17.5rem] onload-animation" headings={headings}></SideBar>}

            <main id="swup-container" class="transition-swup-fade col-span-2 lg:col-span-1 overflow-hidden">
                <div id="content-wrapper" class:list={["onload-animation", {"article-content-wrapper": articleLayout}]}>
                    <!-- the overflow-hidden here prevent long text break the layout-->
                    <!-- make id different from windows.swup global property -->
                    <slot></slot>
                    <div class="footer col-span-2 onload-animation hidden lg:block">
                        <Footer></Footer>
                    </div>
                </div>
            </main>

            <div class="footer col-span-2 onload-animation block lg:hidden">
                <Footer></Footer>
            </div>
        </div>

        <BackToTop></BackToTop>
    </div>
</div>

<!-- The things that should be under the banner, only the TOC for now -->
<div class="absolute w-full z-0 hidden 2xl:block">
    <div class="relative max-w-[var(--page-width)] mx-auto">
        <!-- TOC component -->
        {siteConfig.toc.enable && <div id="toc-wrapper" class:list={["hidden lg:block transition absolute top-0 -right-[var(--toc-width)] w-[var(--toc-width)] items-center",
            {"toc-hide": siteConfig.banner.enable, "toc-article": articleLayout}]}
        >
            <div id="toc-inner-wrapper" class="fixed top-14 w-[var(--toc-width)] h-[calc(100vh_-_20rem)] overflow-y-scroll overflow-x-hidden hide-scrollbar">
                <div id="toc" class="w-full h-full transition-swup-fade ">
                    <div class="h-8 w-full"></div>
                    <TOC headings={headings}></TOC>
                    <div class="h-8 w-full"></div>
                </div>
            </div>
        </div>}

        <!-- #toc needs to exist for Swup to work normally -->
        {!siteConfig.toc.enable && <div id="toc"></div>}
    </div>
</div>
<style is:global>
  body::before {
    content: "";
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    
    background-image: url('/images/re2.jpg'); 
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;

    filter: brightness(0.4); 
  }

  .card-base {
    --tw-bg-opacity: 0.8 !important; 
    background-color: rgba(var(--color-card), 0.8) !important;
    backdrop-filter: blur(10px); 
    -webkit-backdrop-filter: blur(10px);
  }

  .content-glass-card {
    overflow: hidden;
    border-radius: 1.5rem;
    border: 1px solid rgba(226, 232, 240, 0.14);
    background:
      radial-gradient(circle at 12% 4%, rgba(148, 163, 184, 0.14), transparent 22rem),
      linear-gradient(135deg, rgba(15, 23, 42, 0.84), rgba(8, 13, 25, 0.78)),
      rgba(15, 23, 42, 0.76) !important;
    box-shadow:
      0 28px 90px rgba(0, 0, 0, 0.34),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
    color: #cbd5e1;
    backdrop-filter: blur(24px) saturate(0.95);
    -webkit-backdrop-filter: blur(24px) saturate(0.95);
  }

  :root:not(.dark) .content-glass-card {
    background:
      radial-gradient(circle at 12% 4%, rgba(255, 255, 255, 0.58), transparent 22rem),
      linear-gradient(135deg, rgba(248, 250, 252, 0.9), rgba(226, 232, 240, 0.78)),
      rgba(248, 250, 252, 0.82) !important;
    border-color: rgba(15, 23, 42, 0.1);
    color: #334155;
  }

  .content-glass-card .custom-md {
    --tw-prose-body: #cbd5e1;
    --tw-prose-headings: #f8fafc;
    --tw-prose-links: var(--primary);
    --tw-prose-bold: #eef4fb;
    --tw-prose-quotes: #dbe4ef;
    --tw-prose-hr: rgba(226, 232, 240, 0.14);
    color: #cbd5e1;
    line-height: 1.74;
  }

  :root:not(.dark) .content-glass-card .custom-md {
    --tw-prose-body: #334155;
    --tw-prose-headings: #0f172a;
    --tw-prose-bold: #0f172a;
    --tw-prose-quotes: #1e293b;
    --tw-prose-hr: rgba(15, 23, 42, 0.12);
    color: #334155;
  }

  .content-glass-card .custom-md h1,
  .content-glass-card .custom-md h2,
  .content-glass-card .custom-md h3 {
    color: var(--tw-prose-headings);
    letter-spacing: 0;
  }

  #main-grid.article-grid {
    grid-template-columns: minmax(0, 1fr) !important;
    max-width: min(100%, 68rem);
    padding-right: 0.75rem;
    padding-left: 0.75rem;
  }

  #main-grid.article-grid #swup-container,
  #main-grid.article-grid .footer {
    grid-column: 1 / -1 !important;
  }

  #main-grid.article-grid #swup-container {
    overflow: visible;
  }

  #content-wrapper.article-content-wrapper {
    width: 100%;
  }

  @media (min-width: 768px) {
    #main-grid.article-grid {
      padding-right: 1rem;
      padding-left: 1rem;
    }
  }

  .article-frame {
    isolation: isolate;
  }

  #post-container.reading-card {
    overflow: hidden;
  }

  #post-container.reading-card::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    opacity: 0.045;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.38) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.32) 1px, transparent 1px);
    background-size: 4rem 4rem;
    mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.9), transparent 88%);
    pointer-events: none;
  }

  :root.dark #post-container.reading-card {
    background:
      radial-gradient(circle at 12% 4%, rgba(148, 163, 184, 0.14), transparent 22rem),
      linear-gradient(135deg, rgba(15, 23, 42, 0.84), rgba(8, 13, 25, 0.78)),
      rgba(15, 23, 42, 0.76) !important;
  }

  :root:not(.dark) #post-container.reading-card {
    color: #334155;
  }

  #post-container.reading-card [data-pagefind-meta="title"] {
    color: rgba(248, 250, 252, 0.96) !important;
    font-size: clamp(2.05rem, 4vw, 3.05rem);
    line-height: 1.16;
    letter-spacing: 0;
  }

  :root:not(.dark) #post-container.reading-card [data-pagefind-meta="title"] {
    color: rgba(15, 23, 42, 0.94) !important;
  }

  #post-container.reading-card .markdown-content {
    color: #cbd5e1;
    font-size: 1.02rem;
    line-height: 1.78;
  }

  :root:not(.dark) #post-container.reading-card .markdown-content {
    color: #334155;
  }

  #post-container.reading-card .custom-md {
    --tw-prose-body: #cbd5e1;
    --tw-prose-headings: #f8fafc;
    --tw-prose-lead: #dbe4ef;
    --tw-prose-links: var(--primary);
    --tw-prose-bold: #eef4fb;
    --tw-prose-counters: #94a3b8;
    --tw-prose-bullets: #94a3b8;
    --tw-prose-hr: rgba(226, 232, 240, 0.14);
    --tw-prose-quotes: #dbe4ef;
    --tw-prose-quote-borders: rgba(251, 146, 60, 0.55);
    --tw-prose-captions: #94a3b8;
    --tw-prose-code: #f1f5f9;
    --tw-prose-pre-code: #dbeafe;
    --tw-prose-pre-bg: rgba(2, 6, 23, 0.86);
    --tw-prose-th-borders: rgba(226, 232, 240, 0.2);
    --tw-prose-td-borders: rgba(226, 232, 240, 0.12);
  }

  :root:not(.dark) #post-container.reading-card .custom-md {
    --tw-prose-body: #334155;
    --tw-prose-headings: #0f172a;
    --tw-prose-lead: #475569;
    --tw-prose-bold: #0f172a;
    --tw-prose-counters: #64748b;
    --tw-prose-bullets: #64748b;
    --tw-prose-hr: rgba(15, 23, 42, 0.12);
    --tw-prose-quotes: #1e293b;
    --tw-prose-quote-borders: rgba(249, 115, 22, 0.58);
    --tw-prose-captions: #64748b;
    --tw-prose-code: #0f172a;
    --tw-prose-pre-code: #dbeafe;
    --tw-prose-pre-bg: rgba(15, 23, 42, 0.94);
    --tw-prose-th-borders: rgba(15, 23, 42, 0.16);
    --tw-prose-td-borders: rgba(15, 23, 42, 0.1);
  }

  #post-container.reading-card .custom-md p,
  #post-container.reading-card .custom-md ul,
  #post-container.reading-card .custom-md ol {
    margin-top: 1.05em;
    margin-bottom: 1.05em;
  }

  #post-container.reading-card .custom-md li {
    margin-top: 0.35em;
    margin-bottom: 0.35em;
  }

  #post-container.reading-card .custom-md h1,
  #post-container.reading-card .custom-md h2,
  #post-container.reading-card .custom-md h3,
  #post-container.reading-card .custom-md h4 {
    line-height: 1.32;
    letter-spacing: 0;
  }

  #post-container.reading-card .custom-md h2 {
    color: #f8fafc;
    font-size: 1.62rem;
    margin-top: 2.4em;
    padding-top: 0.2rem;
  }

  #post-container.reading-card .custom-md h3 {
    color: #e2e8f0;
    font-size: 1.28rem;
    margin-top: 2em;
  }

  #post-container.reading-card .custom-md h4 {
    color: #cbd5e1;
    font-size: 1.06rem;
  }

  :root:not(.dark) #post-container.reading-card .custom-md h2 {
    color: #0f172a;
  }

  :root:not(.dark) #post-container.reading-card .custom-md h3 {
    color: #1e293b;
  }

  :root:not(.dark) #post-container.reading-card .custom-md h4 {
    color: #334155;
  }

  #post-container.reading-card .custom-md blockquote {
    margin: 1.5rem 0;
    border-radius: 1rem;
    background: rgba(15, 23, 42, 0.38);
    padding: 1rem 1.1rem 1rem 1.35rem;
  }

  :root:not(.dark) #post-container.reading-card .custom-md blockquote {
    background: rgba(255, 255, 255, 0.52);
  }

  #post-container.reading-card .custom-md .katex-display-container,
  #post-container.reading-card .custom-md .expressive-code,
  #post-container.reading-card .custom-md pre,
  #post-container.reading-card .custom-md table {
    max-width: 100%;
  }

  #post-container.reading-card .custom-md .katex-display-container {
    margin: 1.35rem 0;
    border: 1px solid rgba(226, 232, 240, 0.12);
    border-radius: 1rem;
    background: rgba(2, 6, 23, 0.34);
    padding: 0.8rem 1rem;
  }

  :root:not(.dark) #post-container.reading-card .custom-md .katex-display-container {
    border-color: rgba(15, 23, 42, 0.1);
    background: rgba(255, 255, 255, 0.52);
  }

  #post-container.reading-card .custom-md .expressive-code {
    margin: 1.55rem 0;
  }

  #post-container.reading-card .custom-md pre {
    border: 1px solid rgba(226, 232, 240, 0.12);
    box-shadow: 0 18px 46px rgba(0, 0, 0, 0.2);
  }

  #post-container.reading-card .custom-md table {
    display: block;
    overflow-x: auto;
    border-radius: 0.9rem;
  }

  #toc-wrapper.toc-article #toc-inner-wrapper {
    top: 5.35rem;
    height: calc(100vh - 11.5rem);
    border-radius: 1rem;
    background: rgba(15, 23, 42, 0.46);
    padding: 0.7rem;
    box-shadow: 0 18px 54px rgba(0, 0, 0, 0.18);
    backdrop-filter: blur(18px) saturate(0.95);
    -webkit-backdrop-filter: blur(18px) saturate(0.95);
  }
  
  .sidebar-content {
      background-color: rgba(var(--color-card), 0.8) !important;
      backdrop-filter: blur(10px);
  }
</style>
</Layout>
